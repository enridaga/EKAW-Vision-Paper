author = {Masmoudi, Maroua and Ben Abdallah Ben Lamine, Sana and Karray, Mohamed Hedi and Archimede, Bernard and Baazaoui Zghal, Hajer},
title = {Semantic Data Integration and Querying: A Survey and Challenges},
